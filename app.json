{
  "expo": {
    "name": "Gas Money Calculator",
    "slug": "GasMoneyCalculatorApp",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5497a7"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.github.matheos96.gasmoneycalculatorapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2b6265"
      },
      "package": "io.github.matheos96.gasmoneycalculatorapp",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "666dec31-3168-4b28-aedf-ee9aaf42b2f5"
      }
    },
    "plugins": [
      "expo-splash-screen",
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "android": {
            "extraGradleProperties": {
              "org.gradle.workers.max": "8",
              "org.gradle.jvmargs": "-Xmx8192m -XX:MaxMetaspaceSize=1024m -XX:+UseG1GC",
              "org.gradle.daemon.idletimeout": "60000"
            }
          }
        }
      ]
    ]
  }
}
